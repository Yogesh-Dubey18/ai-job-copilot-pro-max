{
  "manifest_version": 3,
  "name": "AI Job Copilot Portal Auto-Scout",
  "version": "1.1.0",
  "description": "Extract job posts and save them to AI Job Copilot Portal Pro MAX.",
  "permissions": ["activeTab", "scripting", "storage", "offscreen"],
  "host_permissions": [
    "http://localhost:5000/*",
    "https://backend-steel-three-33.vercel.app/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Save Job to Copilot",
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}

{
  "manifest_version": 3,
  "name": "AI Job Copilot Auto-Scout",
  "version": "1.0.0",
  "description": "Securely extract job data and send it to AI Job Copilot Pro MAX.",
  "permissions": ["activeTab", "scripting", "storage", "offscreen"],
  "host_permissions": ["http://localhost:5000/*", "https://your-production-api.render.com/*", "<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Save Job to Copilot"
  }
}
